{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSub",
  "version": "1.0.0",
  "identifier": "de.agent-z.opensub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "OpenSub",
        "width": 1500,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Dark",
        "backgroundColor": "#0c0c0e"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "category": "public.app-category.video",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "createUpdaterArtifacts": true,
    "resources": {
      "binaries/": "binaries/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyMzc1ODA0OTA5RUZGNEQKUldSTi81NlFCRmczc3VmZFBSTzkyUXU2OGhidGYyeERlMWplWGRtMDZoajlxdXk3aE1nSVZ0NUcK",
      "endpoints": [
        "https://github.com/ibimspumo/OpenSub/releases/latest/download/latest.json"
      ]
    }
  }
}